itignore\u001b[0m                                                                                   \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1;32m[+] \u001b[0m\u001b[1missues.jsonl (for bv compatibility)\u001b[0m                                                          \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1;33m[*] \u001b[0m\u001b[1mIssue prefix set to 'hello-helix'\u001b[0m                                                            \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m                                                                                                  \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1mLayout:\u001b[0m                                                                                          \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m   .beads/                                                                                        \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     |-- beads.db                                                                                 \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     |-- metadata.json                                                                            \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     |-- config.yaml                                                                              \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     |-- .gitignore                                                                               \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m     `-- issues.jsonl                                                                             \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m                                                                                                  \u001b[90mв”‚\u001b[0m\r\n\u001b[90mв”‚\u001b[0m \u001b[1mNext steps:\u001b[0m                                                                                      \u001b[90mв”‚\u001b[0m\r\n\u001b[9
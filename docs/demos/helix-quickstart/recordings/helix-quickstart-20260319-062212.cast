[189.765021, "o", "function toFahrenheit(c) {\r\n  return c * 9 / 5 + 32;\r\n}\r\n\r\nfunction toCelsius(f) {\r\n  return (f - 32) * 5 / 9;\r\n}\r\n\r\nif (require.main === module) {\r\n  const args = process.argv;\r\n  const toCelsiusIdx = args.indexOf('--to-celsius');\r\n  const toFahrenheitIdx = args.indexOf('--to-fahrenheit');\r\n\r\n  if (toCelsiusIdx !== -1) {\r\n    const val = parseFloat(args[toCelsiusIdx + 1]);\r\n    if (isNaN(val)) {\r\n      process.stderr.write('Usage: convert --to-celsius <temp> | --to-fahrenheit <temp>\\n');"]
[189.765054, "o", "\r\n      process.exit(1);\r\n    }\r\n    const result = toCelsius(val);\r\n    console.log(`${val.toFixed(1)}\\u00b0F = ${result.toFixed(1)}\\u00b0C`);\r\n  } else if (toFahrenheitIdx !== -1) {\r\n    const val = parseFloat(args[toFahrenheitIdx + 1]);"]
[189.76517, "o", "\r\n    if (isNaN(val)) {\r\n      process.stderr.write('Usage: convert --to-celsius <temp> | --to-fahrenheit <temp>\\n');\r\n"]
[189.765305, "o", "...\r\n\r\n"]
